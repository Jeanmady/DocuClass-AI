# DocuClassAI configuration
# Copy to .env and adjust paths for your deployment environment.
# None of these values should contain secrets, they are file paths and
# numeric thresholds. Do not commit .env to version control.

# ---- Model artefact paths ------------------------------------------------
# Absolute or relative paths from the project root.
MODEL_PATH=models/docuclass_minilm
ENCODER_PATH=models/baselines/label_encoder.joblib
CLASS_DEFS_PATH=data/processed/class_definitions.json

# Hugging Face Hub repo for the fine-tuned MiniLM weights.
# If MODEL_PATH is empty on startup, weights are downloaded from this repo automatically.
# Set to empty string to disable auto-download (weights must then be placed manually).
HF_MODEL_REPO=Jeanmady/docuclass-minilm

# ---- Classification thresholds -------------------------------------------
# CONFIDENCE_THRESHOLD: documents with Tier 1 softmax probability below this
# value are escalated to the Mistral-Nemo adjudicator (Tier 2).
# 0.80 was calibrated on the validation set for a risk averse statutory
# context. Do not lower this without re running validation on your corpus.
CONFIDENCE_THRESHOLD=0.80

# FIDELITY_MIN_CHARS: documents with fewer extractable characters than this
# are treated as image based scans and routed to human review rather than
# force classified. Fire Statements disproportionately arrive as scans.
FIDELITY_MIN_CHARS=150

# ---- Mistral-Nemo adjudicator (Tier 2) ------------------------------------
# Ollama must be running locally: `ollama serve`
# Model must be pulled: `ollama pull mistral-nemo`
ADJUDICATOR_URL=http://localhost:11434/api/generate
ADJUDICATOR_MODEL=mistral-nemo

# ---- Web / CORS ------------------------------------------------------------
# Comma separated list of allowed origins for the React frontend.
# Default is the Vite development server.
CORS_ORIGINS=http://localhost:5173
